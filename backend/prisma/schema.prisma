// Smart Parking SPMS - Prisma Schema
// Provider: SQLite
// Database: backend/prisma/dev.db (via .env DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// IDENTITY
// =============================================================================

model Role {
  id   Int    @id @default(autoincrement())
  name String @unique // Admin, Operator, IT, Learner, Faculty

  users User[]
  pricingPolicies PricingPolicy[]
}

model User {
  id          Int     @id @default(autoincrement())
  mssvMscb    String  @unique
  fullName    String
  email       String
  roleId      Int
  role        Role    @relation(fields: [roleId], references: [id])

  cards     Card[]
  auditLogs AuditLog[] @relation("ActorAuditLogs")
}

model Card {
  id      Int     @id @default(autoincrement())
  cardUid String  @unique
  userId  Int?    // Nullable for visitor cards
  status  String  // Active, Disabled

  user            User?             @relation(fields: [userId], references: [id])
  parkingSessions ParkingSession[]
}

// =============================================================================
// INFRASTRUCTURE
// =============================================================================

model Device {
  id     Int    @id @default(autoincrement())
  type   String // SENSOR, GATEWAY, CAMERA, SIGNAGE
  x      Float  // % position on map
  y      Float  // % position on map
  status String @default("ONLINE") // ONLINE, OFFLINE, ERROR

  slot                 Slot?
  infrastructureAlerts InfrastructureAlert[]
}

model Slot {
  id       Int    @id @default(autoincrement())
  label    String
  deviceId Int    @unique // 1-1 with Device (type SENSOR)
  status   String @default("AVAILABLE") // AVAILABLE, OCCUPIED
  device   Device @relation(fields: [deviceId], references: [id])
}

// =============================================================================
// TRANSACTIONS
// =============================================================================

model ParkingSession {
  id           Int       @id @default(autoincrement())
  cardId       Int
  licensePlate String
  entryTime    DateTime
  exitTime     DateTime?
  fee          Float
  status       String    @default("ONGOING") // ONGOING, COMPLETED

  card Card @relation(fields: [cardId], references: [id])

  // Note: No direct relation to Slot - sensor does not track which vehicle is where
}

// =============================================================================
// BILLING & POLICY
// =============================================================================

model BillingCycle {
  id        Int      @id @default(autoincrement())
  name      String   // Tháng 03/2026, Học kỳ 2
  startDate DateTime
  endDate   DateTime
}

model PricingPolicy {
  id          Int    @id @default(autoincrement())
  roleId      Int
  vehicleType String // Motorcycle, Car
  baseFee     Float
  hourlyRate  Float

  role Role @relation(fields: [roleId], references: [id])
}

// =============================================================================
// AUDITING
// =============================================================================

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int
  action    String
  target    String
  reason    String?  // For manual barrier open
  timestamp DateTime @default(now())

  actor User @relation("ActorAuditLogs", fields: [actorId], references: [id])
}

model InfrastructureAlert {
  id         Int     @id @default(autoincrement())
  deviceId   Int
  message    String
  severity   String  // critical, warning, error
  isResolved Boolean @default(false)

  device Device @relation(fields: [deviceId], references: [id])
}
